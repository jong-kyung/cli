{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "tui": {
    "enabled": false
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": ["default"]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "cache": true,
      "dependsOn": ["^build", "build"],
      "inputs": ["default", "^production"]
    },
    "test:e2e:blocking": {
      "cache": true,
      "dependsOn": ["^build", "build"],
      "inputs": ["default", "^production"]
    },
    "test:e2e:matrix": {
      "cache": true,
      "dependsOn": ["^build", "build"],
      "inputs": ["default", "^production"]
    }
  }
}
